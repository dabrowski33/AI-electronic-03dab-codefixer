# ============================================================
# CodeFixer AI — Zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości
# .env jest gitignored — nigdy nie commituj kluczy API
# ============================================================

# --- LLM: OpenRouter (dostawca główny — Hermes 3) ---
# Klucz z: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Modele rozdzielone (opcjonalnie, dla backendu Java)
OPENROUTER_TEXT_MODEL=nousresearch/hermes-3-llama-3.1-405b
OPENROUTER_VISION_MODEL=openai/gpt-4o

# --- LLM: OpenAI (fallback po 2 nieudanych próbach OpenRouter) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- PostgreSQL ---
POSTGRES_USER=codefixer
POSTGRES_PASSWORD=codefixer_secret_change_me
POSTGRES_DB=codefixer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Context7 MCP (opcjonalnie — docs-aware coding) ---
CONTEXT7_API_KEY=ctx7sk-...

# --- Serwisy (dev) ---
# Frontend  : http://localhost:5173
# Gateway   : http://localhost:3001
# Agent     : http://localhost:8000
# Backend   : http://localhost:8080
# PostgreSQL: localhost:5432
